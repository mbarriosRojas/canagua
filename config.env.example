# Configuración de Base de Datos
DB_HOST=localhost
DB_NAME=sacrgapi_database
DB_USER=sacrgapi_user
DB_PASS=sacrgapi_password_2024

# Configuración de la Aplicación
APP_NAME="Sistema SACRGAPI"
APP_URL=http://localhost/SACRGAPI/public
APP_ENV=development

# Configuración de Sesiones
SESSION_LIFETIME=3600
SESSION_NAME=SACRGAPI_SESSION

# Configuración de Seguridad
ENCRYPTION_KEY=your_secret_key_here_change_in_production
JWT_SECRET=your_jwt_secret_here_change_in_production

# Correo (recuperación de clave)
MAIL_FROM=noreply@tudominio.com
MAIL_FROM_NAME=Sistema SACRGAPI

# SMTP (opcional). Para Gmail use contraseña de aplicación: Cuenta Google > Seguridad > Verificación en 2 pasos > Contraseñas de aplicaciones
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
MAIL_SMTP_SECURE=tls
